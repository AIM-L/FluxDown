---
import Layout from "../layouts/Layout.astro";
import { FloatingNavbar } from "../components/ui/floating-navbar";
import Footer from "../components/Footer";
---

<Layout
  title="Stats - FluxDown"
  description="FluxDown website real-time traffic statistics powered by OpenPanel."
>
  <FloatingNavbar client:load />
  <main class="relative min-h-screen pt-24 pb-16">
    <!-- Background ambiance -->
    <div class="absolute inset-0 -z-10 overflow-hidden pointer-events-none">
      <div class="absolute top-0 left-1/2 -translate-x-1/2 w-[700px] h-[350px] bg-brand-sky/[0.04] blur-[130px] rounded-full"></div>
      <div class="absolute top-1/3 left-1/4 w-[400px] h-[300px] bg-brand-cyan/[0.03] blur-[100px] rounded-full"></div>
      <div class="absolute bottom-1/4 right-1/4 w-[350px] h-[280px] bg-brand-blue/[0.03] blur-[100px] rounded-full"></div>
    </div>

    <div class="mx-auto max-w-5xl px-4 sm:px-6 lg:px-8">
      <!-- Page header -->
      <div class="mb-10 text-center">
        <div class="inline-flex items-center gap-2 rounded-full border border-brand-sky/20 bg-brand-sky/5 px-3 py-1 mb-5">
          <span class="relative flex h-2 w-2">
            <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-brand-sky opacity-75"></span>
            <span class="relative inline-flex rounded-full h-2 w-2 bg-brand-sky"></span>
          </span>
          <span class="text-xs font-medium text-brand-sky tracking-wide">LIVE</span>
        </div>

        <h1 class="text-3xl sm:text-4xl font-bold tracking-tight">
          <span class="bg-gradient-to-r from-brand-sky via-brand-cyan to-brand-blue bg-clip-text text-transparent">
            Real-time Stats
          </span>
        </h1>
        <p class="mt-3 text-sm text-dark-text-secondary max-w-md mx-auto">
          Live website traffic overview, powered by&nbsp;
          <a
            href="https://openpanel.dev"
            target="_blank"
            rel="noopener noreferrer"
            class="text-brand-sky hover:text-brand-cyan transition-colors duration-200"
          >
            OpenPanel
          </a>
        </p>
      </div>

      <!-- Widget container -->
      <div class="rounded-xl border border-dark-border/60 bg-dark-surface1/50 backdrop-blur-sm overflow-hidden shadow-xl shadow-black/20">
        <div class="px-4 py-3 border-b border-dark-border/40 flex items-center justify-between">
          <div class="flex items-center gap-2">
            <div class="h-3 w-3 rounded-full bg-red-500/70"></div>
            <div class="h-3 w-3 rounded-full bg-yellow-500/70"></div>
            <div class="h-3 w-3 rounded-full bg-green-500/70"></div>
          </div>
          <span class="text-xs text-dark-text-muted font-mono">fluxdown.app · realtime</span>
          <div class="w-14"></div>
        </div>
        <iframe
          src="https://openpanel.zerx.dev/widget/realtime?shareId=Cmeyzm"
          width="100%"
          height="480"
          frameborder="0"
          loading="lazy"
          title="FluxDown real-time traffic stats"
          class="block w-full"
        ></iframe>
      </div>

      <!-- Footer note -->
      <p class="mt-6 text-center text-xs text-dark-text-muted/60">
        Data updates in real time · Tracked via self-hosted OpenPanel
      </p>
    </div>
  </main>
  <Footer client:load />
</Layout>
